# Base de datos (Neon o Supabase, plan gratuito)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Firma de la cookie de sesión y del estado OAuth. Generar con: openssl rand -hex 32
SESSION_SECRET=""

# URL pública de la app (sin barra final). En local: http://localhost:3000
APP_URL="https://tu-proyecto.vercel.app"

# --- Mercado Pago ---
# Credenciales de TU aplicación registrada en https://www.mercadopago.cl/developers/panel
# (usar credenciales de PRODUCCIÓN recién al final; en sandbox usar las de prueba)
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_REDIRECT_URI="https://tu-proyecto.vercel.app/api/mp/oauth/callback"
# Access token de TU aplicación (no el de cada amiga) — se usa para leer pagos vía webhook
MP_ACCESS_TOKEN=""
# Secret para validar la firma HMAC de los webhooks (Panel > Tu app > Webhooks > Firma secreta)
MP_WEBHOOK_SECRET=""

# --- Web Push (VAPID) ---
# Generar con: npm run generate-vapid
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-email@ejemplo.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Secret para proteger el endpoint de recordatorios (Vercel Cron lo envía automáticamente
# como Authorization: Bearer $CRON_SECRET si está seteado como env var del proyecto)
CRON_SECRET=""
